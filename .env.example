# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_BATCH_SIZE=100
OPENAI_REQUEST_TIMEOUT=30
OPENAI_MAX_RETRIES=3

# Hugging Face Configuration (optional)
HUGGINGFACE_API_KEY=

# Retrieval Configuration
DENSE_TOP_K=50
BM25_TOP_K=50
RRF_CONSTANT=60
RERanker_TOP_K=30
FINAL_CONTEXT_K=6
SIMILARITY_THRESHOLD=0.5

# Chunking Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MIN_CHUNK_SIZE=100
MAX_CHUNK_SIZE=1000

# LLM Configuration
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# OCR Configuration
ENABLE_OCR=true
OCR_BATCH_SIZE=5
SKIP_OCR_CONFIDENCE_THRESHOLD=0.8

# Cache Configuration
ENABLE_EMBEDDING_CACHE=true
ENABLE_RETRIEVAL_CACHE=true
ENABLE_CONTEXT_CACHE=true
ENABLE_LLM_RESPONSE_CACHE=true
CACHE_EMBEDDING_TTL=604800
CACHE_RETRIEVAL_TTL=3600
CACHE_CONTEXT_TTL=1800
CACHE_LLM_RESPONSE_TTL=3600

# Logging Configuration
LOG_LEVEL=INFO
STRUCTURED_LOGS=true

# Path Configuration
UPLOADED_DOCS_DIR=data/uploaded_docs
FAISS_INDEX_DIR=data/faiss_index
CACHE_DIR=data/cache
LOGS_DIR=logs

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_RELOAD=false

# System Configuration
ENVIRONMENT=development
ENABLE_MONITORING=true
